{
  "// 说明": "超觅官网 OSS 静态托管配置。此文件供 oss-deploy.sh 读取，也方便记录 Bucket 元信息。",
  "bucket": "ultraseek-website",
  "region": "oss-cn-hangzhou",
  "endpoint": "oss-cn-hangzhou.aliyuncs.com",
  "storageClass": "Standard",
  "acl": "public-read",
  "website": {
    "indexDocument": "index.html",
    "errorDocument": "index.html"
  },
  "// 自定义域名": "绑定后可在 OSS 控制台 → 传输管理 → 域名管理 中配置 CNAME",
  "customDomain": "www.chaomifilter.com",
  "// HTTPS": "通过阿里云 SSL 证书服务申请免费证书，绑定到 CDN 或 OSS",
  "https": {
    "enabled": true,
    "certSource": "aliyun-free-cert"
  },
  "// CDN 加速": "推荐开启 CDN 回源到 OSS，提升全国访问速度",
  "cdn": {
    "enabled": true,
    "cdnDomain": "cdn.chaomifilter.com",
    "origin": "ultraseek-website.oss-cn-hangzhou.aliyuncs.com"
  }
}
